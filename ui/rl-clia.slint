import {
    Button, LineEdit, ComboBox, TextEdit,
    VerticalBox, HorizontalBox, Palette, ScrollView,
} from "std-widgets.slint";

component FormField inherits HorizontalLayout {
    in property <string> label;
    in-out property <string> value;
    in property <bool> readonly: false;
    spacing: 8px;
    Text { text: root.label; vertical-alignment: center; min-width: 72px; font-size: 14px; font-weight: 600; }
    LineEdit { text <=> root.value; read-only: root.readonly; horizontal-stretch: 1; }
}

component FormCombo inherits HorizontalLayout {
    in property <string> label;
    in-out property <int> index;
    in property <[string]> model;
    spacing: 8px;
    Text { text: root.label; vertical-alignment: center; min-width: 72px; font-size: 14px; font-weight: 600; }
    ComboBox { current-index <=> root.index; model: root.model; horizontal-stretch: 1; }
}

component SmallField inherits HorizontalLayout {
    in property <string> label;
    in-out property <string> value;
    spacing: 4px;
    Text { text: root.label; vertical-alignment: center; font-size: 14px; min-width: 36px; }
    LineEdit { text <=> root.value; horizontal-stretch: 1; }
}

component NavButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;
    height: 48px;
    background: root.active ? #0A9CEE : transparent;
    border-radius: 6px;
    Text { text: root.label; color: root.active ? white : #333; font-size: 14px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { root.clicked(); } }
}

export component RLCLIAWindow inherits Window {
    in-out property <string> page: "home";
    in-out property <string> enc-page: "reagent";
    in-out property <[string]> project-names: [];
    in-out property <[string]> project-ids: [];

    in-out property <int> reagent-project-index: 0;
    in-out property <string> reagent-lot;
    in-out property <string> reagent-prod-date;
    in-out property <string> reagent-valid-days: "365";
    in-out property <string> reagent-expire-date;
    in-out property <string> reagent-test-counts: "50";
    in-out property <string> reagent-open-days: "28";
    in-out property <string> reagent-serial-count: "1";
    in-out property <int> reagent-unit-index: 0;
    in-out property <string> reagent-param-a; in-out property <string> reagent-param-b;
    in-out property <string> reagent-param-c; in-out property <string> reagent-param-d;
    in-out property <string> reagent-range-low; in-out property <string> reagent-range-upper;
    in-out property <string> reagent-limit-low; in-out property <string> reagent-limit-upper;

    in-out property <int> calib-project-index: 0;
    in-out property <string> calib-lot;
    in-out property <string> calib-prod-date;
    in-out property <string> calib-valid-days: "365";
    in-out property <string> calib-expire-date;
    in-out property <string> calib-quantity: "1";
    in-out property <string> calib-c1; in-out property <string> calib-c2;

    in-out property <int> consumable-type-index: 0;
    in-out property <string> consumable-lot;
    in-out property <string> consumable-prod-date;
    in-out property <string> consumable-valid-days: "365";
    in-out property <string> consumable-expire-date;
    in-out property <string> consumable-freq: "2000";
    in-out property <string> consumable-open-days: "28";
    in-out property <string> consumable-quantity: "1";

    in-out property <int> quality-project-index: 0;
    in-out property <string> quality-lot;
    in-out property <string> quality-prod-date;
    in-out property <string> quality-valid-days: "365";
    in-out property <string> quality-expire-date;
    in-out property <string> quality-quantity: "1";
    in-out property <string> quality-q1; in-out property <string> quality-sd1;
    in-out property <string> quality-q2; in-out property <string> quality-sd2;

    in-out property <image> preview-reagent;
    in-out property <bool> has-preview-reagent: false;
    in-out property <image> preview-calibration;
    in-out property <bool> has-preview-calibration: false;
    in-out property <image> preview-consumable;
    in-out property <bool> has-preview-consumable: false;
    in-out property <image> preview-quality;
    in-out property <bool> has-preview-quality: false;

    out property <image> current-preview: enc-page == "reagent" ? preview-reagent : enc-page == "calibration" ? preview-calibration : enc-page == "consumable" ? preview-consumable : preview-quality;
    out property <bool> has-current-preview: enc-page == "reagent" ? has-preview-reagent : enc-page == "calibration" ? has-preview-calibration : enc-page == "consumable" ? has-preview-consumable : has-preview-quality;

    in-out property <string> decrypt-input;
    in-out property <string> decrypt-output;

    in-out property <string> status: "就绪";
    in-out property <string> toast-msg;
    in-out property <bool> toast-visible: false;

    callback generate-preview(string);
    callback export-png(string);
    callback export-pdf(string);
    callback decrypt-data();
    pure callback compute-expiry(string, string) -> string;

    changed reagent-prod-date => { reagent-expire-date = compute-expiry(reagent-prod-date, reagent-valid-days); }
    changed reagent-valid-days => { reagent-expire-date = compute-expiry(reagent-prod-date, reagent-valid-days); }
    changed calib-prod-date => { calib-expire-date = compute-expiry(calib-prod-date, calib-valid-days); }
    changed calib-valid-days => { calib-expire-date = compute-expiry(calib-prod-date, calib-valid-days); }
    changed consumable-prod-date => { consumable-expire-date = compute-expiry(consumable-prod-date, consumable-valid-days); }
    changed consumable-valid-days => { consumable-expire-date = compute-expiry(consumable-prod-date, consumable-valid-days); }
    changed quality-prod-date => { quality-expire-date = compute-expiry(quality-prod-date, quality-valid-days); }
    changed quality-valid-days => { quality-expire-date = compute-expiry(quality-prod-date, quality-valid-days); }

    title: "化学发光条码工具";
    icon: @image-url("../assets/RL-CLIA-icon.ico");
    width: 980px;
    height: 850px;

    // HOME
    if page == "home": VerticalLayout {
        alignment: center; spacing: 32px;
        Text { text: "化学发光条码信息生成工具"; font-size: 24px; font-weight: 700; horizontal-alignment: center; }
        HorizontalLayout { alignment: center; spacing: 40px;
            Rectangle { width: 200px; height: 140px; background: t1.has-hover ? #FF9030 : #FE8701; border-radius: 12px;
                animate background { duration: 200ms; }
                Text { text: "加 密"; color: white; font-size: 28px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                t1 := TouchArea { clicked => { root.page = "enc"; } }
            }
            Rectangle { width: 200px; height: 140px; background: t2.has-hover ? #40DDAA : #37CC9D; border-radius: 12px;
                animate background { duration: 200ms; }
                Text { text: "解 密"; color: white; font-size: 28px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                t2 := TouchArea { clicked => { root.page = "dec"; } }
            }
        }
    }

    // ENCRYPT
    if page == "enc": HorizontalLayout {
        Rectangle { width: 130px; background: #F0F0F0;
            VerticalLayout { padding: 10px; spacing: 6px;
                NavButton { label: "首页"; active: false; clicked => { root.page = "home"; } }
                NavButton { label: "试 剂"; active: enc-page == "reagent"; clicked => { enc-page = "reagent"; } }
                NavButton { label: "校准品"; active: enc-page == "calibration"; clicked => { enc-page = "calibration"; } }
                NavButton { label: "耗 材"; active: enc-page == "consumable"; clicked => { enc-page = "consumable"; } }
                NavButton { label: "质控品"; active: enc-page == "quality"; clicked => { enc-page = "quality"; } }
            }
        }

        HorizontalLayout { spacing: 12px; padding: 12px;
            // Form area — each form has its own scroll with buttons inside
            VerticalLayout { width: 440px;
                if enc-page == "reagent": ScrollView { VerticalLayout { spacing: 8px; padding-bottom: 8px;
                    Text { text: "试剂信息"; font-size: 16px; font-weight: 700; }
                    FormCombo { label: "项目名称"; index <=> reagent-project-index; model: project-names; }
                    FormField { label: "项目编号"; value: project-ids[reagent-project-index]; readonly: true; }
                    FormField { label: "试剂批号"; value <=> reagent-lot; }
                    FormField { label: "生产日期"; value <=> reagent-prod-date; }
                    FormField { label: "有效天数"; value <=> reagent-valid-days; }
                    FormField { label: "失效日期"; value: reagent-expire-date; readonly: true; }
                    FormField { label: "测试/盒"; value <=> reagent-test-counts; }
                    FormField { label: "开瓶天数"; value <=> reagent-open-days; }
                    FormField { label: "数量"; value <=> reagent-serial-count; }
                    FormCombo { label: "结果单位"; index <=> reagent-unit-index; model: ["pg/mL", "ng/mL", "mg/L", "ng/L", "IU/L"]; }
                    Text { text: "曲线参数"; font-size: 13px; font-weight: 600; }
                    HorizontalLayout { spacing: 8px; SmallField { label: "a"; value <=> reagent-param-a; } SmallField { label: "b"; value <=> reagent-param-b; } }
                    HorizontalLayout { spacing: 8px; SmallField { label: "c"; value <=> reagent-param-c; } SmallField { label: "d"; value <=> reagent-param-d; } }
                    Text { text: "结果参数"; font-size: 13px; font-weight: 600; }
                    HorizontalLayout { spacing: 8px; SmallField { label: "下限"; value <=> reagent-range-low; } SmallField { label: "上限"; value <=> reagent-range-upper; } }
                    HorizontalLayout { spacing: 8px; SmallField { label: "限低"; value <=> reagent-limit-low; } SmallField { label: "限高"; value <=> reagent-limit-upper; } }
                    Rectangle { height: 12px; }
                    HorizontalLayout { spacing: 10px;
                        Button { text: "生成预览"; primary: true; clicked => { root.generate-preview("reagent"); } }
                        Button { text: "导出PNG"; clicked => { root.export-png("reagent"); } }
                        Button { text: "导出PDF"; clicked => { root.export-pdf("reagent"); } }
                    }
                    Text { text: status; color: #888; font-size: 11px; horizontal-alignment: right; }
                }}

                if enc-page == "calibration": ScrollView { VerticalLayout { spacing: 8px; padding-bottom: 8px;
                    Text { text: "校准品信息"; font-size: 16px; font-weight: 700; }
                    FormCombo { label: "项目名称"; index <=> calib-project-index; model: project-names; }
                    FormField { label: "项目编号"; value: project-ids[calib-project-index]; readonly: true; }
                    FormField { label: "校准批号"; value <=> calib-lot; }
                    FormField { label: "生产日期"; value <=> calib-prod-date; }
                    FormField { label: "有效天数"; value <=> calib-valid-days; }
                    FormField { label: "失效日期"; value: calib-expire-date; readonly: true; }
                    FormField { label: "数量"; value <=> calib-quantity; }
                    FormField { label: "C1 发光值"; value <=> calib-c1; }
                    FormField { label: "C2 发光值"; value <=> calib-c2; }
                    Rectangle { height: 12px; }
                    HorizontalLayout { spacing: 10px;
                        Button { text: "生成预览"; primary: true; clicked => { root.generate-preview("calibration"); } }
                        Button { text: "导出PNG"; clicked => { root.export-png("calibration"); } }
                        Button { text: "导出PDF"; clicked => { root.export-pdf("calibration"); } }
                    }
                    Text { text: status; color: #888; font-size: 11px; horizontal-alignment: right; }
                }}

                if enc-page == "consumable": ScrollView { VerticalLayout { spacing: 8px; padding-bottom: 8px;
                    Text { text: "耗材信息"; font-size: 16px; font-weight: 700; }
                    FormCombo { label: "耗材类型"; index <=> consumable-type-index; model: ["激发液A", "激发液B"]; }
                    FormField { label: "耗材批号"; value <=> consumable-lot; }
                    FormField { label: "生产日期"; value <=> consumable-prod-date; }
                    FormField { label: "有效天数"; value <=> consumable-valid-days; }
                    FormField { label: "失效日期"; value: consumable-expire-date; readonly: true; }
                    FormField { label: "可用频次"; value <=> consumable-freq; }
                    FormField { label: "开瓶天数"; value <=> consumable-open-days; }
                    FormField { label: "数量"; value <=> consumable-quantity; }
                    Rectangle { height: 12px; }
                    HorizontalLayout { spacing: 10px;
                        Button { text: "生成预览"; primary: true; clicked => { root.generate-preview("consumable"); } }
                        Button { text: "导出PNG"; clicked => { root.export-png("consumable"); } }
                        Button { text: "导出PDF"; clicked => { root.export-pdf("consumable"); } }
                    }
                    Text { text: status; color: #888; font-size: 11px; horizontal-alignment: right; }
                }}

                if enc-page == "quality": ScrollView { VerticalLayout { spacing: 8px; padding-bottom: 8px;
                    Text { text: "质控品信息"; font-size: 16px; font-weight: 700; }
                    FormCombo { label: "项目名称"; index <=> quality-project-index; model: project-names; }
                    FormField { label: "项目编号"; value: project-ids[quality-project-index]; readonly: true; }
                    FormField { label: "质控批号"; value <=> quality-lot; }
                    FormField { label: "生产日期"; value <=> quality-prod-date; }
                    FormField { label: "有效天数"; value <=> quality-valid-days; }
                    FormField { label: "失效日期"; value: quality-expire-date; readonly: true; }
                    FormField { label: "数量"; value <=> quality-quantity; }
                    HorizontalLayout { spacing: 8px; SmallField { label: "Q1"; value <=> quality-q1; } SmallField { label: "SD1"; value <=> quality-sd1; } }
                    HorizontalLayout { spacing: 8px; SmallField { label: "Q2"; value <=> quality-q2; } SmallField { label: "SD2"; value <=> quality-sd2; } }
                    Rectangle { height: 12px; }
                    HorizontalLayout { spacing: 10px;
                        Button { text: "生成预览"; primary: true; clicked => { root.generate-preview("quality"); } }
                        Button { text: "导出PNG"; clicked => { root.export-png("quality"); } }
                        Button { text: "导出PDF"; clicked => { root.export-pdf("quality"); } }
                    }
                    Text { text: status; color: #888; font-size: 11px; horizontal-alignment: right; }
                }}
            }

            // Preview area
            Rectangle { horizontal-stretch: 1;
                border-width: 1px; border-color: Palette.border; border-radius: 6px;
                background: Palette.alternate-background;
                if !has-current-preview: Text { text: "点击「生成预览」查看条码"; color: #999; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                if has-current-preview: Image { source: current-preview; image-fit: contain; width: 100%; height: 100%; }
            }
        }
    }

    // DECRYPT
    if page == "dec": VerticalLayout { padding: 24px; spacing: 16px;
        Text { text: "解密工具"; font-size: 20px; font-weight: 700; }
        Text { text: "输入密文:"; font-size: 13px; font-weight: 600; }
        Rectangle { height: 120px; border-width: 1px; border-color: Palette.border; border-radius: 4px;
            TextEdit { x: 8px; y: 8px; width: parent.width - 16px; height: parent.height - 16px; text <=> decrypt-input; }
        }
        HorizontalLayout { spacing: 12px;
            Button { text: "解密"; primary: true; clicked => { root.decrypt-data(); } }
            Button { text: "返回首页"; clicked => { root.page = "home"; } }
        }
        Text { text: "解密结果:"; font-size: 13px; font-weight: 600; }
        Rectangle { vertical-stretch: 1; border-width: 1px; border-color: Palette.border; border-radius: 4px; background: #F8F8F8;
            ScrollView { Text { x: 8px; y: 8px; width: parent.width - 16px; text: decrypt-output; font-size: 13px; font-family: "monospace"; wrap: word-wrap; } }
        }
    }

    // Toast
    property <float> toast-alpha: toast-visible ? 1.0 : 0.0;
    animate toast-alpha { duration: 250ms; }
    Timer { interval: 2000ms; running: toast-visible; triggered => { toast-visible = false; } }
    Rectangle { opacity: toast-alpha; x: (parent.width - 300px) / 2; y: parent.height - 60px; width: 300px; height: 36px; background: #333; border-radius: 18px;
        Text { text: toast-msg; color: white; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
        TouchArea { clicked => { toast-visible = false; } }
    }
}
